{
  "manifest_version": 3,
  "name": "Chrome Resizer",
  "version": "1.0.0",
  "description": "Instantly resizes the current browser window to your desired resolution. Supports presets, custom sizes, and keyboard shortcuts.",
  "author": "KANJSEOK <kanjseok@gmail.com>",
  "permissions": ["windows", "storage", "system.display"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chrome Resizer",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "resize-1": {
      "suggested_key": {
        "default": "Alt+Shift+1"
      },
      "description": "Apply preset 1"
    },
    "resize-2": {
      "suggested_key": {
        "default": "Alt+Shift+2"
      },
      "description": "Apply preset 2"
    },
    "resize-3": {
      "suggested_key": {
        "default": "Alt+Shift+3"
      },
      "description": "Apply preset 3"
    },
    "resize-4": {
      "suggested_key": {
        "default": "Alt+Shift+4"
      },
      "description": "Apply preset 4"
    }
  }
}
